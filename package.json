{
  "name": "product-endpoint",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker:dev": "tsx watch src/worker.ts",
    "db:up": "docker compose up -d",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:gen": "prisma generate --no-hints",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio --browser none",
    "db:reset": "prisma migrate reset "
  },
  "dependencies": {
    "@anvia/core": "^0.12.1",
    "@anvia/openai": "^0.3.15",
    "@hono/node-server": "^2.0.6",
    "@hono/zod-openapi": "^1.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scalar/hono-api-reference": "^0.11.7",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "hono": "^4.12.27",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
